# ===== TestHub backend — PRODUCTION env namunasi =====
# Bu fayldan nusxa olib Render'ga (yoki serverga) kiriting. ".env" sifatida saqlamang — Render dashboard'ga qo'ying.

# --- Ma'lumotlar bazasi (Neon PostgreSQL) ---
# Neon dashboard > Connection string. ?sslmode=require bo'lishi shart.
DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/testhub?sslmode=require"

# --- JWT ---
JWT_SECRET="bu-yerga-uzun-tasodifiy-maxfiy-kalit"

# --- Super admin telefon raqami ---
# Ishga tushganda bu raqam(lar) avtomatik SUPER_ADMIN bo'ladi (yo'q bo'lsa yaratiladi).
# Vergul bilan bir nechta raqam berish mumkin.
SUPER_ADMIN_PHONE="+998901234567"

# --- Frontend manzili (CORS uchun) ---
# Vergul bilan bir nechta domen berish mumkin
FRONTEND_URL="https://testhub.vercel.app"

# --- OpenRouter (bepul vision AI) ---
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="nex-agi/nex-n2-pro:free,google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,nvidia/nemotron-nano-12b-v2-vl:free"

# --- Cloudflare R2 (rasm saqlash) ---
# R2 dashboard > Manage R2 API Tokens. Public bucket yoki custom domain yoqing!
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY="..."
R2_SECRET_KEY="..."
R2_BUCKET="testhub-uploads"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# --- Ixtiyoriy ---
ESKIZ_EMAIL=""
ESKIZ_PASSWORD=""
TELEGRAM_BOT_TOKEN=""
